{
  "name": "uos-quality-gate",
  "version": "2.1.0",
  "description": "Evidence-centric Paperclip quality gate workbench with a reviewer queue, dashboard widget, auditable evidence bundles, and human-in-the-loop release controls.",
  "type": "module",
  "scripts": {
    "test": "tsx --test tests/**/*.test.ts",
    "plugin:typecheck": "tsc --noEmit",
    "plugin:lint": "eslint . --max-warnings 0",
    "plugin:format": "bunx prettier --check .",
    "plugin:build": "node esbuild.config.mjs",
    "plugin:dev": "node esbuild.config.mjs --watch",
    "security:audit": "npm audit",
    "prepublishOnly": "npm run plugin:build",
    "test:ts": "tsx --test tests/**/*.test.ts",
    "docs:images": "python3 scripts/generate-doc-images.py"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@paperclipai/plugin-sdk": "^2026.416.0",
    "@paperclipai/shared": "^2026.416.0",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "esbuild": "^0.28.0",
    "globals": "^17.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.59.1"
  }
}
